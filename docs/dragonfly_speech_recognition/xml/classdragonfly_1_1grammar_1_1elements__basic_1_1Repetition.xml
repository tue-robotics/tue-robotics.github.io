        <detaileddescription>
<para><verbatim>    The *value* of a :class:`Repetition` is a list containing
    the values of its child.

    The length of this list is equal to the number of times
    that the child element was recognized.</verbatim> </para>        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="src/dragonfly_speech_recognition/dragonfly/dragonfly/grammar/elements_basic.py" line="628" column="1" bodyfile="src/dragonfly_speech_recognition/dragonfly/dragonfly/grammar/elements_basic.py" bodystart="628" bodyend="642"/>
      </memberdef>
