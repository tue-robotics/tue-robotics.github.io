        <definition>outlook_example.folder_rule</definition>
        <argsstring></argsstring>
        <name>folder_rule</name>
        <initializer>=  MappingRule(
    name=&quot;folder&quot;,
    mapping={
             &quot;folder &lt;folder&gt;&quot;:   Key(&quot;c-1, home&quot;)
                                   + Text(&quot;%(folder)s\n&quot;)
                                   + Key(&quot;space, tab&quot;),
             &quot;move to &lt;folder&gt;&quot;:  Key(&quot;cs-v, home/10&quot;)
                                   + Text(&quot;%(folder)s&quot;)
                                   + Pause(&quot;75&quot;)
                                   + Key(&quot;enter&quot;),
            },
    extras=[
            Choice(&quot;folder&quot;, folder_map),
           ],
    )</initializer>
